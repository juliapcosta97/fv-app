# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → Project Settings → API

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# For GitHub Pages: set this to /nome-do-repo/ (with trailing slash)
# Example: if your repo is github.com/user/futevolei → VITE_BASE=/futevolei/
# Leave as '/' for local dev or Vercel/Netlify
VITE_BASE=/
